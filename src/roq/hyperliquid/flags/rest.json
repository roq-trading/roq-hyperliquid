{
  "name": "roq/hyperliquid/flags/REST",
  "type": "flags",
  "prefix": "rest_",
  "values": [
    {
      "name": "uri",
      "type": "roq/io/web/URI",
      "validator": "roq/core/flags/URI",
      "default": "https://api.hyperliquid-testnet.xyz",
      "description": "Exchange end-point"
    },
    {
      "name": "host",
      "type": "std/string",
      "description": "Host (when URI is an IP address)"
    },
    {
      "name": "proxy",
      "type": "roq/io/web/URI",
      "validator": "roq/core/flags/URI",
      "description": "Proxy end-point"
    },
    {
      "name": "ping_freq",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "ping_path",
      "type": "std/string",
      "validator": "roq/flags/validators/Path",
      "description": "Ping path"
    },
    {
      "name": "request_timeout",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "30s",
      "description": "Request timeout"
    },
    {
      "name": "recv_window",
      "type": "std/milliseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "30s",
      "description": "Receive window (please refer to exchange documentation)"
    },
    {
      "name": "terminate_on_403",
      "type": "std/bool",
      "default": false,
      "description": "(TEST) Trigger program termination after receiving a 403 response code?"
    },
    {
      "name": "back_off_delay",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "30s",
      "description": "(TEST) Time to wait before retrying a rejected request"
    }
  ]
}
